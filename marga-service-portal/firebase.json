{
  "hosting": {
    "public": ".",
    "cleanUrls": true,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=600"
          }
        ]
      },
      {
        "source": "**/*.@(svg|png|jpg|jpeg|webp)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=86400"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/install",
        "destination": "/install/index.html"
      },
      {
        "source": "/install/**",
        "destination": "/install/index.html"
      },
      {
        "source": "/tech/**",
        "destination": "/public/tech/index.html"
      },
      {
        "source": "**",
        "destination": "/public/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
